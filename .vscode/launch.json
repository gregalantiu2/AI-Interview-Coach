{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API (http)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/AIInterviewCoach.Api/AIInterviewCoach.Api.csproj",
      "launchSettingsProfile": "http"
    },
    {
      "name": "Web (Vite)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "preLaunchTask": "Start Vite Dev Server",
      "webRoot": "${workspaceFolder}/src/ai-interview-coach-web/src"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["API (http)", "Web (Vite)"],
      "stopAll": true
    }
  ]
}
